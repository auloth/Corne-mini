/*
 * Clean working keymap for Corne Mini - compatible with ZMK
 */

 / {
    chosen { zmk,physical-layout = &foostan_corne_5col_layout; };

    combos {
        compatible = "zmk,combos";

        next_tab {
            bindings = <&kp LC(TAB)>;
            key-positions = <20 21>;
        };

        prev_tab {
            bindings = <&kp LC(LS(TAB))>;
            key-positions = <19 20>;
        };

        new_tab {
            bindings = <&kp LC(T)>;
            key-positions = <33 32>;
        };

        delete_tab {
            bindings = <&kp LC(W)>;
            key-positions = <32 31>;
        };

        close_program {
            bindings = <&kp LA(F4)>;
            key-positions = <32 33 31>;
        };

        open_terminal {
            bindings = <&kp LC(LA(T))>;
            key-positions = <3 2 4>;
        };

        switch_program {
            bindings = <&kp LA(TAB)>;
            key-positions = <19 20 21>;
        };

        next_virtual {
            bindings = <&kp LA(RIGHT)>;
            key-positions = <16 15>;
        };

        prev_virtual {
            bindings = <&kp LA(LEFT)>;
            key-positions = <14 15>;
        };

        right_monitor {
            bindings = <&kp LS(LG(RIGHT))>;
            key-positions = <3 16>;
        };

        left_monitor {
            bindings = <&kp LS(LG(LEFT))>;
            key-positions = <3 14>;
        };

        window_next_desktop {
            bindings = <&kp LS(LG(PAGE_UP))>;
            key-positions = <27 28>;
        };

        window_prev_desktop {
            bindings = <&kp LS(LG(PAGE_DOWN))>;
            key-positions = <26 27>;
        };

        snap_right {
            bindings = <&kp LG(RIGHT)>;
            key-positions = <8 9>;
        };

        snap_left {
            bindings = <&kp LG(LEFT)>;
            key-positions = <8 7>;
        };

        maximize {
            bindings = <&kp LG(UP)>;
            key-positions = <9 7 8>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default {
            bindings = <
                &trans  &kp Q  &kp W  &kp E  &kp R  &kp T  &kp Y  &kp U  &kp I  &kp O  &kp P  &trans
                &trans  &kp A  &kp S  &kp D  &kp F  &kp G  &kp H  &kp J  &kp K  &kp L  &kp SQT &trans
                &trans  &kp Z  &kp X  &kp C  &kp V  &kp B  &kp N  &kp M  &kp LCTL &kp LALT &kp DOT &trans
                          &kp LGUI  &kp TAB  &kp SPACE  &kp ESC  &kp ENTER  &kp BSPC  &trans
            >;
        };

        layer_1 {
            bindings = <
                &trans &trans &kp RC  &kp UP  &kp LC &trans &trans &kp SCRL_UP &kp UP &kp SCRL_DOWN &trans &trans
                &trans &trans &kp LEFT &kp DOWN &kp RIGHT &trans &bt BT_CLR &kp LEFT &kp DOWN &kp RIGHT &trans &trans
                &trans &trans &trans &trans &trans &trans &bt BT_SEL 0 &bt BT_SEL 1 &bt BT_SEL 2 &bt BT_SEL 3 &trans &trans
                          &trans &trans &trans &trans &trans &trans &trans
            >;
        };

        layer_2 {
            bindings = <
                &trans &kp LEFT_PAREN &kp RIGHT_PAREN &kp BACKSLASH &kp PIPE &kp HASH &kp EQUAL &kp N7 &kp N8 &kp N9 &kp PLUS &trans
                &trans &kp LEFT_BRACKET &kp RIGHT_BRACKET &kp EXCL &kp QUESTION &kp AMPERSAND &kp SLASH &kp N4 &kp N5 &kp N6 &kp N0 &trans
                &trans &kp LEFT_BRACE &kp RIGHT_BRACE &kp LESS &kp GREATER &kp AT &kp ASTERISK &kp N1 &kp N2 &kp N3 &kp MINUS &trans
                          &trans &trans &trans &trans &trans &trans &trans
            >;
        };
    };
};
